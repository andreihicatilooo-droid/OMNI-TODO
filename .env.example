# ==========================================================================
# OAuth Web Flow — учётные данные для интеграции нейросетей
# Скопируйте этот файл в .env и заполните значениями из консолей провайдеров.
# .env в git не попадает (см. .gitignore).
# ==========================================================================

# --- Google Gemini ---
# Создайте OAuth Client (тип "Web application") в Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Авторизованный redirect URI: http://localhost:1337/api/auth/gemini/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub Copilot ---
# Создайте OAuth App в настройках GitHub:
# https://github.com/settings/developers
# Authorization callback URL: http://localhost:1337/api/auth/copilot/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Claude Code (Anthropic) ---
# Redirect URI: http://localhost:1337/api/auth/claude/callback
ANTHROPIC_CLIENT_ID=
ANTHROPIC_CLIENT_SECRET=
# Необязательно: переопределить эндпоинты OAuth
# ANTHROPIC_AUTH_URL=https://claude.ai/oauth/authorize
# ANTHROPIC_TOKEN_URL=https://console.anthropic.com/v1/oauth/token

# --- Telegram login widget ---
# Имя Telegram-бота для виджета входа (например: myapp_bot)
VITE_TELEGRAM_BOT_USERNAME=
# Опциональный абсолютный callback URL для Telegram login widget.
VITE_TELEGRAM_CALLBACK_URL=http://localhost:3001/api/auth/telegram/callback
# Токен Telegram-бота, который используется для проверки данных входа на сервере.
TELEGRAM_BOT_TOKEN=
